# =============================================================================
# Configuración de TTFA KPI Ingest (copiar a .env y completar)
# =============================================================================

# -----------------------------------------------------------------------------
# Microsoft Graph (autenticación app-only / client credentials)
# Ver docs/SETUP_AZURE.md para el paso a paso de registro de la app.
# -----------------------------------------------------------------------------
MS_TENANT_ID=00000000-0000-0000-0000-000000000000
MS_CLIENT_ID=00000000-0000-0000-0000-000000000000
MS_CLIENT_SECRET=pegar-aqui-el-secreto-de-la-app
# Buzón a leer (UPN, ej. tpozo@ttfasa.com). La app necesita Mail.Read sobre este buzón.
MS_MAILBOX=tpozo@ttfasa.com

# -----------------------------------------------------------------------------
# Fuente CHILE — Furlong (Alexis Yáñez)
# -----------------------------------------------------------------------------
CHILE_SENDER=Alexis.yanez@furlong.cl
CHILE_SUBJECT_PREFIX=Reporte tasa
# Nombre exacto del adjunto. Puede ser sustring (case-insensitive).
CHILE_ATTACHMENT_NAME=REPORTE DE ARRIBOS.xlsx
CHILE_SHEET=ARRIBOS

# -----------------------------------------------------------------------------
# Fuente BRASIL — Furlong (Ailén Deretich)
# -----------------------------------------------------------------------------
BRASIL_SENDER=ailen.deretich@furlong.com.ar
BRASIL_SUBJECT_PREFIX=REPORTE DAÑOS DESCARGAS
# Regex para matchear el nombre del adjunto (la fecha varía).
BRASIL_ATTACHMENT_PATTERN=Reporte de Da.os.*\.xlsx$
BRASIL_SHEET=DAÑOS
# Compañía a filtrar dentro de la hoja DAÑOS. Valores típicos: TTFA, TRANSPORTE FURLONG, AUTOPORT.
BRASIL_COMPANY=TTFA

# -----------------------------------------------------------------------------
# Comportamiento general
# -----------------------------------------------------------------------------
# Cuántos días para atrás revisar mails en cada corrida.
LOOKBACK_DAYS=14
# Si MARK_AS_READ=true, los mails procesados se marcan como leídos en Outlook.
# Requiere permiso Mail.ReadWrite además de Mail.Read.
MARK_AS_READ=false

# -----------------------------------------------------------------------------
# Rutas (dentro del contenedor)
# -----------------------------------------------------------------------------
STATE_PATH=/app/state/state.json
OUTPUT_DIR=/app/output
DOWNLOADS_DIR=/app/downloads

# -----------------------------------------------------------------------------
# Modo de ejecución del contenedor
# RUN_MODE=once   → corre una vez y termina (útil para CI o cron externo)
# RUN_MODE=cron   → corre el scheduler interno con CRON_SCHEDULE
# -----------------------------------------------------------------------------
RUN_MODE=cron
# Cron estándar (m h dom mon dow). Default: cada 30 minutos.
CRON_SCHEDULE=*/30 * * * *
TZ=America/Argentina/Buenos_Aires
